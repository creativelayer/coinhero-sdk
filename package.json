{
  "name": "@coinhero/sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "import": "./dist/host.js",
      "default": "./dist/host.js"
    },
    "./connector": {
      "types": "./dist/app/connector.d.ts",
      "import": "./dist/app/connector.js",
      "default": "./dist/app/connector.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@wagmi/core": ">=2.0.0",
    "jose": ">=5.0.0",
    "viem": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@wagmi/core": {
      "optional": true
    },
    "jose": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@wagmi/core": "^2.16.0",
    "jose": "^6.2.1",
    "jsdom": "^29.0.0",
    "typescript": "^5.8.3",
    "viem": "^2.21.0",
    "vitest": "^4.1.0"
  }
}
